{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "nodeVersion": "22.19.0",
      "npmVersion": "10.9.3",
      "nodePackageManager": "npm",
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "production": {
      "nodeVersion": "22.19.0",
      "npmVersion": "10.9.3",
      "nodePackageManager": "npm",
      "android": { "buildType": "apk" },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
